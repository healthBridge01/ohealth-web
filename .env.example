# Copy to `.env.local` for development:
#   cp .env.example .env.local

# Site URL for SEO / Open Graph (see src/lib/constants/seo.ts). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# Contact form (Resend) — required in production for /contact submissions
RESEND_API_KEY=re_xxxxxxxx

# Verified sender domain in Resend (required in production)
CONTACT_FROM_EMAIL=hello@yourdomain.com

# Inbox for contact form (optional; default: support@ohealthltd.com)
CONTACT_TO_EMAIL=support@example.com
