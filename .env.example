# Copy to `.env.local` for development:
#   cp .env.example .env.local
#
# Copy to `.env.production` for production builds, or set the same keys in your host.

# Site URL for SEO / Open Graph (see src/lib/constants/seo.ts getSiteUrl). No trailing slash.
# Priority: NEXT_PUBLIC_SITE_URL → SITE_URL → VERCEL_URL (on Vercel) → http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# SMTP (contact form) — same pattern as portfolio /api/contact
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-smtp-user@example.com
SMTP_PASSWORD=your_smtp_app_password

# Contact form delivery (optional overrides)
CONTACT_TO_EMAIL=support@ohealthltd.com
CONTACT_FROM_EMAIL=your-smtp-user@example.com
