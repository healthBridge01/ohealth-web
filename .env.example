# Copy to `.env.local` for development:
#   cp .env.example .env.local

# Canonical site URL for SEO, Open Graph, and sitemap (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact form (Resend) — required in production for /contact submissions
RESEND_API_KEY=re_xxxxxxxx

# Verified sender domain in Resend (required in production)
CONTACT_FROM_EMAIL=hello@yourdomain.com

# Inbox for contact form (optional; default: support@ohealthltd.com)
CONTACT_TO_EMAIL=support@example.com

# Upstash Redis for contact-form rate limiting (required in production CI/Vercel builds)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudinary image CDN (optional; default: doeoxmyna)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# E2E only — Playwright sets E2E=true automatically (never set in production)
# E2E=true

# Public marketing links (omit until URLs are live)
NEXT_PUBLIC_APP_CTA_URL=/contact
NEXT_PUBLIC_IOS_APP_URL=
NEXT_PUBLIC_ANDROID_APP_URL=
NEXT_PUBLIC_SOCIAL_X_URL=
NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=
NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=
NEXT_PUBLIC_SOCIAL_GITHUB_URL=
NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=
NEXT_PUBLIC_SOCIAL_TIKTOK_URL=
