# Copy to `.env.local` for development:
#   cp .env.example .env.local
#
# Copy to `.env.production` for production builds, or set the same keys in your host.

# Public site URL (SEO / Open Graph). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# Contact form (optional overrides)
CONTACT_TO_EMAIL=support@ohealthltd.com
CONTACT_FROM_EMAIL=OHealth+ Website <onboarding@resend.dev>
